pipeline {
    agent any

    environment {        
        SPRING_PROFILES_ACTIVE="prod"

        API_HOST_PORT=8100
        API_CONTAINER_PORT=8100

        API_IMAGE_NAME="dainf-labs-api"
        API_CONTAINER_NAME="dainf-labs-api"
        
        CLIENT_HOST_PORT=8101
        CLIENT_CONTAINER_PORT=80
        
        CLIENT_IMAGE_NAME="dainf-labs-client"
        CLIENT_CONTAINER_NAME="dainf-labs-client"

        POSTGRESQL_CRED = credentials('postgres-id')
        DATABASE_URL="jdbc:postgresql://postgresql:5432/labs_dainf"
        DATABASE_USERNAME="${POSTGRESQL_CRED_USR}"
        DATABASE_PASSWORD="${POSTGRESQL_CRED_PSW}"
        
        EMAIL_CRED = credentials('UTFPRAPPSEmailAndPassword')
        MAIL_USERNAME="${EMAIL_CRED_USR}"
        MAIL_PASSWORD="${EMAIL_CRED_PSW}"
        MAIL_HOST="smtp.utfpr.edu.br"
        MAIL_PORT=587

        MINIO_CRED = credentials('dainf_labs_minio_id')
        MINIO_URL="https://minio.app.pb.utfpr.edu.br"
        MINIO_BUCKET="dainf-labs"
        MINIO_ACCESS_KEY="${MINIO_CRED_USR}"
        MINIO_SECRET_KEY="${MINIO_CRED_PSW}"
        MINIO_SECURE=true
        MINIO_PORT=443

        API_HOST_URL="dainf-labs-api.app.pb.utfpr.edu.br"
        API_URL="https://dainf-labs-api.app.pb.utfpr.edu.br/api"
        CLIENT_HOST_URL="dainf-labs.app.pb.utfpr.edu.br"
        CLIENT_URL="https://dainf-labs.app.pb.utfpr.edu.br"
        BASE_URL="https://dainf-labs.app.pb.utfpr.edu.br"
    }

    stages {   
        stage('Build via Docker Compose') {
            steps {
                sh 'docker compose --profile app up -d --build'                
            }
        }
    }
}
